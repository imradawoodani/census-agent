# Snowflake credentials
SNOWFLAKE_ACCOUNT=your-account-identifier   # e.g. abc12345 or orgname-accountname
SNOWFLAKE_USER=your-snowflake-username
SNOWFLAKE_PASSWORD=your-snowflake-password
SNOWFLAKE_DATABASE=US_OPEN_CENSUS
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=COMPUTE_WH

# DigitalOcean inference — all LLM calls (Llama 3.3 70B, Llama 3.1 8B)
# DO Dashboard → AI → Serverless Inference → Create Model Access Key
DO_MODEL_ACCESS_KEY=your-do-model-access-key

# Cohere — embeddings only (schema retrieval + few-shot + field retrieval)
# Free tier: 1000 calls/month. Field embeddings are disk-cached after first run.
# dashboard.cohere.com → API Keys
COHERE_API_KEY=your-cohere-api-key

# Optional: Redis for persistent sessions (falls back to in-memory if not set)
# REDIS_URL=rediss://your-redis-connection-string

# Logging (json recommended for production, text for local dev)
LOG_LEVEL=INFO
LOG_FORMAT=json
